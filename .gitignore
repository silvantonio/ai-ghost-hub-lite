# Ignore environment files
.env
.env.*
!.env.example

# Ignore Python cache
__pycache__/
*.py[cod]

# Ignore node modules
node_modules/

# Ignore Docker volumes and logs
data/
logs/
*.log

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore VS Code settings
.vscode/

# Ignore build artifacts
dist/
build/

# Ignore coverage reports
coverage/
*.cover

# Ignore backup files
*~
*.swp
*.bak
