# n8n environment variables
OLLAMA_MODELS=phi3:mini
AI_GHOST_HUB_LITE_GPU=false
N8N_IMAGE=n8nio/n8n:latest
POSTGRES_IMAGE=postgres:15
REDIS_IMAGE=redis:7
OLLAMA_IMAGE=ollama/ollama:latest
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=db
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=n8npass
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379

# Required for n8n worker encryption
N8N_ENCRYPTION_KEY=your-strong-random-key

# Postgres database
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8npass
POSTGRES_DB=n8n

# OpenWebUI
OLLAMA_BASE_URL=http://ollama:11434

# Cloudflare Tunnel configuration
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_NAME=ai-ghost-hub-lite-tunnel
CLOUDFLARE_TUNNEL_URL=https://your-tunnel-name.trycloudflare.com
